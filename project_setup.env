###########################################################
# Author:   Raunak Rajpal (rsrajpal@bu.edu)
# Company:  WISE Circuits Lab, Boston University
# 
# Brief:    User defined variables/paths
#           for build 
###########################################################
###########################################################

##  Evaluation Board
EVAL_BD=adrv9361z7035

##  Carrier Board
CARRIER=ccbob_cmos

##  Device Family : [zynq, zynqMP, versal]
PART_FAM=zynq
part=

##  Architecture (arm, arm64, microblaze, x86 ..)
ARCH=arm

##  Project Name
proj_name=""


##  Device Tree srcs/path
# ----------------------------------------------------------------
# Supported Xilinx boards, including zynq-adrv9361-z7035-bob, are
# loctaed in the directory: $LINUX_DIR/arch/arm/boot/dts/xilinx/
# ----------------------------------------------------------------
DTFILE=xilinx/zynq-adrv9361-z7035-bob.dts


##  OS : [y/n]      (linux - y | bare-metal/RTOS - n)
OS=y
IMG_NAME=uImage

##  U-Boot (.elf) core dump
# ----------------------------------------------------------------
# If you have a custom ELF, provide its path here. If don't know 
# what file to pick or you're running the build flow for the first
# time, leave this empty or set to "download" 
# ----------------------------------------------------------------
uboot_elf=u-boot_zynq_adrv9361.elf


##  Xilinx Version
# ----------------------------------------------------------------
# You must specify the Xilinx installation version, even if you're
# building on a host machine. If you intend to build just the 
# kernel, enter any placeholder value.
# ----------------------------------------------------------------  
XVERSION="2024.1"
