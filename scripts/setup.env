####################################################################


##  HDL build paths
ADI_DIR=${WS}
HDL_DIR=${ADI_DIR}/hdl
HDL_PROJ=${ADI_DIR}/pl-proj/${proj_name}
XPR_ROOT=${HDL_DIR}/projects/${EVAL_BD}/${CARRIER}

# HDL_SRCS=${WS}/hdl-proj/${proj_name}/srcs
# HDL_CNSTR=${WS}/hdl-proj/${proj_name}/constr
XSA_FILE=${HDL_PROJ}/${EVAL_BD}-${CARRIER}-${proj_name}_build/system_top.xsa


##  Path to Linux kernel build directory
LINUX_DIR=${WS}/linux-adi
lnx_branch=main

SYSMOD_DIR=${WS}/build/${proj_name}/sysmod_rootfs
lnx_config_file=${part}-${EVAL_BD}-${proj_name}.config


##  Path to BOOT bin
BOOT_DIR=${WS}/build/${proj_name}/BOOT
BUILD_BOOT_DIR=${BOOT_DIR}/build_boot_bin
OUTPUT_DIR=${BOOT_DIR}/output_boot_bin
UBOOT_FILE=${BOOT_DIR}/${uboot_elf}
PKG_BOOT=${WS}/BIN_pkg

##  Xilinx version 



#   /////////////   Dependency Paths    /////////////

##      Path to Xilinx binaries
# ----------------------------------------------------------------
# Specify the path to the Vivado installation to use for the build
#
# If left unset, the build system will fall back to the specified
# Vivado version on the SCC (if available). 
# If you are not building on the SCC, it is strongly recommended 
# to set them explicitly.
# ----------------------------------------------------------------
XVIVADO=
XVITIS=


##      Cross-Compiler (GCC) toolchain path
# ----------------------------------------------------------------
# Specify the cross-compiler prefix path to use for the build.
#
# A Linaro GCC 7.5.0 (2019.12) toolchain is pre-installed in the
# Singularity container and can be used by uncommenting the line
# below. Alternatively, set CROSS_COMPILE to the prefix path of
# any other installed cross-compiler toolchain.
# ----------------------------------------------------------------
# CROSS_COMPILE="/lib/gcc-linaro-7.5.0-2019.12-x86_64_arm-linux-gnueabi/bin/arm-linux-gnueabi-"
CROSS_COMPILE=




############################### SCC ################################
#------------------------------------------------------------------#

###  Current version support for xilinx SWs on ENG-SCC ###
XSDK_VERSIONS="2018.2  2019.1  2020.2  2021.2  2022.1  2024.1"
ARCHS_XLNX="arm  arm64  armr5  microblaze  riscv"


##  Path to Xilinx binaries
XVIVADO_24V1=/ad/eng/opt/Xilinx/2024.1/Vivado/2024.1
XVITIS_24V1=/ad/eng/opt/Xilinx/2024.1/Vitis/2024.1

XVIVADO_22V1=/ad/eng/opt/Xilinx/Vivado/2022.1/Vivado/2022.1
XVITIS_22V1=${XVIVADO_22V1}     # bootgen, xsdb,.. already present inside vivado/bin

XVIVADO_21V2=/ad/eng/opt/Xilinx/Vivado.2021.2/Vivado/2021.2
XVITIS_21V2=${XVIVADO_21V2}     # bootgen, xsdb,.. already present inside vivado/bin

XVIVADO_20V2=/ad/eng/opt/Xilinx/Vivado/2020.2
XVITIS_20V2=${XVIVADO_20V2}     # bootgen, xsdb,.. already present inside vivado/bin

XVIVADO_19V1=/ad/eng/opt/Xilinx/Vivado/2019.1/Vivado/2019.1
XSDK_19V1=/ad/eng/opt/Xilinx/Vivado/2019.1/SDK/2019.1

XVIVADO_18V2=/ad/eng/opt/Xilinx/Vivado/2018.2/Vivado/2018.2
XSDK_18V2=/ad/eng/opt/Xilinx/Vivado/2018.2/SDK/2018.2

##------- Deprecated -------
# XVIVADO_15V4=/ad/eng/opt/Xilinx/Vivado/2015.4/Vivado/2015.4
# XVITIS_15V4=???-----------


##  Path to the Xilinx Cross-Compiler toolchains 
XLNX_AARCH32_NON_CC__PATH=gnu/aarch32/lin/gcc-arm-none-eabi/bin
XLNX_AARCH32_LNX_CC__PATH=gnu/aarch32/lin/gcc-arm-linux-gnueabi/bin
XLNX_AARCH64_NON_CC__PATH=gnu/aarch64/lin/aarch64-none/bin
XLNX_AARCH64_LNX_CC__PATH=gnu/aarch64/lin/aarch64-linux/bin
XLNX_ARMR5_NON_CC__PATH=gnu/armr5/lin/gcc-arm-none-eabi/bin
XLNX_MB_NON_CC__PATH=gnu/microblaze/lin/bin
XLNX_MB_LNX_CC__PATH=gnu/microblaze/linux_toolchain/lin64_le/bin
XLNX_RISCV_NON_CC__PATH=gnu/riscv/lin/riscv64-unknown-elf/bin

XLNX_ARM_NON_CC=${XLNX_AARCH32_NON_CC__PATH}/arm-none-eabi-
XLNX_ARM_LNX_CC=${XLNX_AARCH32_LNX_CC__PATH}/arm-linux-gnueabihf-
XLNX_ARM64_NON_CC=${XLNX_AARCH64_NON_CC__PATH}/aarch64-none-elf-
XLNX_ARM64_LNX_CC=${XLNX_AARCH64_LNX_CC__PATH}/aarch64-linux-gnu-
XLNX_ARMR5_ELF_CC=${XLNX_ARMR5_NON_CC__PATH}/armr5-none-eabi-
XLNX_MB_NON_CC=${XLNX_MB_NON_CC__PATH}/mb-
XLNX_MB_LNX_CC=${XLNX_MB_LNX_CC__PATH}/microblazeel-xilinx-linux-gnu-
XLNX_RISCV_ELF_CC=${XLNX_RISCV_NON_CC__PATH}/riscv64-unknown-elf-

